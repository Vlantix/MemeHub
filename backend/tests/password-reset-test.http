### ========================================
### PASSWORD RESET TESTS
### ========================================
@host = {{$dotenv HOST}}
@reset_token = {{$dotenv RESET_TOKEN}}

### === STEP 1: REQUEST OTP ===

### 1. Forgot Password (Valid)
POST {{host}}/auth/forgot-password
Content-Type: application/json

{
    "email": "bonzakent16@gmail.com"
}

### 2. Forgot Password (Non-existent email - returns 200 for security)
POST {{host}}/auth/forgot-password
Content-Type: application/json

{
    "email": "notreal@example.com"
}

### 3. Forgot Password (Missing email - 400)
POST {{host}}/auth/forgot-password
Content-Type: application/json

{}

### === STEP 2: VERIFY OTP ===

### 4. Verify OTP (Valid - returns reset_token)
POST {{host}}/auth/verify-reset-otp
Content-Type: application/json

{
    "otp": "208504"
}

### 5. Verify OTP (Invalid/expired code - 400)
POST {{host}}/auth/verify-reset-otp
Content-Type: application/json

{
    "otp": "123456"
}

### 6. Verify OTP (Missing OTP - 400)
POST {{host}}/auth/verify-reset-otp
Content-Type: application/json

{}

### === STEP 3: RESET PASSWORD ===

### 7. Reset Password (Valid)
POST {{host}}/auth/reset-password
Content-Type: application/json

{
    "reset_token": "{{reset_token}}",
    "new_password": "kenken123"
}

### 8. Reset Password (Expired/invalid reset_token - 401)
POST {{host}}/auth/reset-password
Content-Type: application/json

{
    "reset_token": "invalid.token.here",
    "new_password": "newpassword123"
}

### 9. Reset Password (Weak password - 400)
POST {{host}}/auth/reset-password
Content-Type: application/json

{
    "reset_token": "{{reset_token}}",
    "new_password": "abc"
}

### 10. Reset Password (Missing fields - 400)
POST {{host}}/auth/reset-password
Content-Type: application/json

{}

### === STEP 4: VERIFY NEW PASSWORD ===

### 11. Login with new password (should succeed)
POST {{host}}/auth/login
Content-Type: application/json

{
    "username": "kent12345",
    "password": "kenken123"
}

### 12. Login with old password (should fail - 401)
POST {{host}}/auth/login
Content-Type: application/json

{
    "username": "kent12345",
    "password": "123456"
}