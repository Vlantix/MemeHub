### ========================================
### PASSWORD RESET TESTS
### ========================================
@host = {{$dotenv HOST}}
@reset_token = {{$dotenv RESET_TOKEN}}

### === REQUEST RESET ===

### 1. Forgot Password (Valid)
POST {{host}}/auth/forgot-password
Content-Type: application/json

{
    "email": "bonzakent16@gmail.com"
}

### 2. Forgot Password (Invalid Email - returns 200 for security)
POST {{host}}/auth/forgot-password
Content-Type: application/json

{
    "email": "notreal@example.com"
}

### 3. Forgot Password (Missing Email - 400)
POST {{host}}/auth/forgot-password
Content-Type: application/json

{}

### === RESET PASSWORD ===

### 4. Reset Password (Success)
POST {{host}}/auth/reset-password
Content-Type: application/json

{
    "token": "{{reset_token}}",
    "new_password": "12345678"
}

### 5. Reset Password (Used Token - 400)
POST {{host}}/auth/reset-password
Content-Type: application/json

{
    "token": "{{reset_token}}",
    "new_password": "newpassword123"
}

### 6. Reset Password (Missing Fields - 400)
POST {{host}}/auth/reset-password
Content-Type: application/json

{}

### 7. Reset Password (Weak Password - 400)
POST {{host}}/auth/reset-password
Content-Type: application/json

{
    "token": "{{reset_token}}",
    "new_password": "abc"
}

### === VERIFY NEW PASSWORD ===

### 8. Login with New Password
POST {{host}}/auth/login
Content-Type: application/json

{
    "username": "johndoe",
    "password": "newpassword123"
}

### 9. Login with Old Password (Should Fail)
POST {{host}}/auth/login
Content-Type: application/json

{
    "username": "kent12345",
    "password": "123456"
}